{
  "name": "@ccsight/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "ccsight": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && esbuild src/cli.ts --bundle --platform=node --format=esm --target=es2023 --define:BUNDLED=true --outfile=dist/cli.js",
    "dev": "tsx src/server.ts"
  },
  "dependencies": {
    "@ccsight/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3"
  }
}
