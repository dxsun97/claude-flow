{
  "name": "ccsight",
  "version": "0.1.0",
  "description": "Dashboard for visualizing Claude Code session data",
  "type": "module",
  "bin": {
    "ccsight": "packages/server/dist/cli.js"
  },
  "files": [
    "packages/server/dist/",
    "packages/web/dist/",
    "packages/shared/dist/"
  ],
  "scripts": {
    "dev": "pnpm run --parallel -r dev",
    "dev:web": "pnpm --filter @ccsight/web dev",
    "dev:server": "pnpm --filter @ccsight/server dev",
    "build": "pnpm run -r build",
    "build:shared": "pnpm --filter @ccsight/shared build",
    "build:server": "pnpm --filter @ccsight/server build",
    "build:web": "pnpm --filter @ccsight/web build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node packages/server/dist/cli.js",
    "prepublishOnly": "pnpm run build"
  },
  "author": "dxsun97",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxsun97/claude-flow"
  },
  "homepage": "https://github.com/dxsun97/claude-flow#readme",
  "bugs": {
    "url": "https://github.com/dxsun97/claude-flow/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "session-viewer",
    "dashboard",
    "analytics",
    "viewer",
    "token-usage",
    "tool-calls"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
